<UserControl x:Class="Storage_Manage.Views.ThongKeDoanhThuUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Storage_Manage.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <!-- Phần tổng cộng đã chỉnh size -->
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Từ ngày:" VerticalAlignment="Center" Margin="5" FontSize="20"/>
            <DatePicker Margin="5" FontSize="20"/>
            <TextBlock Text="Đến ngày:" VerticalAlignment="Center" Margin="5" FontSize="20"/>
            <DatePicker Margin="5" FontSize="20"/>
            <Button Content="Thống kê" Width="100" Margin="5" Background="LightGreen" FontSize="20"/>
        </StackPanel>

        <DataGrid Grid.Row="1" AutoGenerateColumns="True" Name="dgStatistic">
            <!-- Sau này sẽ hiển thị danh sách doanh thu -->
        </DataGrid>

       
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <TextBlock Text="Tổng doanh thu: " FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding TotalRevenue, StringFormat='{}{0:N0} VNĐ'}" 
           FontSize="20" 
           Foreground="Red" 
           FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</UserControl>
