<UserControl x:Class="StorageManage.Views.Report"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StorageManage.Views"
             xmlns:vm="clr-namespace:StorageManage.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Border BorderBrush="Gray" BorderThickness="1" Padding="20">

        <StackPanel>

            <TextBlock Text="BÁO CÁO DANH SÁCH SẢN PHẨM"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding NgayLap, StringFormat=Ngày lập: {0:dd/MM/yyyy}}"
                       HorizontalAlignment="Right"
                       Margin="0,5,0,15"/>

            <DataGrid ItemsSource="{Binding DanhSachSanPham}"
                      AutoGenerateColumns="False"
                      Height="300"
                      IsReadOnly="True"
                      CanUserAddRows="False">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Mã SP" Binding="{Binding MaSP}" Width="*" />
                    <DataGridTextColumn Header="Tên SP" Binding="{Binding TenSP}" Width="2*" />
                    <DataGridTextColumn Header="Số lượng" Binding="{Binding SoLuong}" Width="*" />
                    <DataGridTextColumn Header="Giá" Binding="{Binding Gia}" Width="*" />
                </DataGrid.Columns>

            </DataGrid>

            <StackPanel Margin="0,15,0,0">
                <TextBlock Text="Người lập: Admin"
                           HorizontalAlignment="Right"/>

                <TextBlock Text="(Ký và ghi rõ họ tên)"
                           FontStyle="Italic"
                           HorizontalAlignment="Right"/>
            </StackPanel>

        </StackPanel>

    </Border>
</UserControl>