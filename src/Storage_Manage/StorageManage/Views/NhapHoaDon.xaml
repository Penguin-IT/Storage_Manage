<UserControl x:Class="Storage_Manage.Views.NhapHoaDon"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Storage_Manage.Views"
             xmlns:vm="clr-namespace:StorageManage.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="1024">
    <UserControl.DataContext>
        <vm:NhapHoaDon/>
    </UserControl.DataContext>
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="93*"/>
            <ColumnDefinition Width="931*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="LightGray" Grid.ColumnSpan="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Nhập Kho / Tạo Hóa Đơn Nhập" FontSize="40" FontWeight="Bold" Margin="20,15,0,15" VerticalAlignment="Center"/>
            <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock Text="{Binding MaPhieu, StringFormat='Mã phiếu: {0}'}" FontSize="16" Foreground="#666" FontStyle="Italic" HorizontalAlignment="Right"/>
                <TextBlock Text="Người lập: Nguyễn Hữu Nhật (NV01)" FontSize="18" Foreground="#107C41" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="15,15,15,15" Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nhà cung cấp" FontSize="23" FontWeight="Bold"/>
            <Border Grid.Row="1" Grid.Column="0" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="35" Width="450" Margin="0,10,0,10">
                <TextBox Text="{Binding MaNCC, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="10,0" VerticalContentAlignment="Center" FontSize="15" />
            </Border>
            <TextBlock Grid.Row="0" Grid.Column="1" Text="Ngày nhập" FontSize="23" FontWeight="Bold" Margin="25,0,-12,55" Grid.RowSpan="2"/>
            <Border Grid.Row="1" Grid.Column="1" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="35" Width="300" Margin="10,12,204,8">
                <DatePicker SelectedDate="{Binding NgayNhap}" BorderThickness="0" 
                            Background="Transparent" VerticalContentAlignment="Center"
                            Padding="5,0,0,0" xml:lang="vi-VN"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Margin="15,15,15,15" Background="LightGray" Grid.ColumnSpan="2">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Mã SP" FontSize="18" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="1" Text="Tên sản phẩm" FontSize="18" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Đơn giá" FontSize="18" FontWeight="Bold" Margin="0,0,10,5"/>
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Số lượng" FontSize="18" FontWeight="Bold" Margin="0,0,10,5"/>

                <Border Grid.Row="1" Grid.Column="0" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="40" Background="White" Margin="0,0,10,0">
                    <TextBox Text="{Binding MaSP, UpdateSourceTrigger=LostFocus}" BorderThickness="0" Background="Transparent" Padding="10,0" VerticalContentAlignment="Center" FontSize="15"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="40" Background="#EAEAEA" Margin="0,0,10,0">
                    <TextBox Text="{Binding TenSanPham}" BorderThickness="0" Background="Transparent" Padding="10,0" VerticalContentAlignment="Center" FontSize="15" IsReadOnly="True" Foreground="#555"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="2" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="40" Background="White" Margin="0,0,10,0">
                    <TextBox Text="{Binding DonGiaNhap, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="10,0" VerticalContentAlignment="Center" FontSize="15"/>
                </Border>
                <Border Grid.Row="1" Grid.Column="3" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="40" Background="White" Margin="0,0,20,0">
                    <TextBox Text="{Binding SoLuong, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" Padding="10,0" VerticalContentAlignment="Center" FontSize="15"/>
                </Border>
                <Border Grid.Column="4" Grid.Row="1" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="45" Width="200" Background="DarkGreen">
                    <Button BorderThickness="0" Background="Transparent" Padding="10,0" Content="+ Thêm vào hóa đơn" Foreground="White" FontSize="18" FontWeight="Bold" Cursor="Hand"
                            Command="{Binding AddDetailCommand}"/>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="3" CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Margin="15,0,15,10" Background="LightGray" Grid.ColumnSpan="2">
            <DataGrid x:Name="dgDanhSach"
                      ItemsSource="{Binding DsCTSP}" 
                      SelectedItem="{Binding SelectedCTSP, Mode=TwoWay}" 
                      AutoGenerateColumns="False" CanUserAddRows="False" 
                      RowHeight="40" ColumnHeaderHeight="45" 
                      Background="Transparent" RowBackground="White" 
                      AlternatingRowBackground="#F2F4F8" 
                      HorizontalGridLinesBrush="#E5E5E5" 
                      VerticalGridLinesBrush="#E5E5E5">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="Padding" Value="5,10,5,10"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="STT" Width="60" Binding="{Binding STT}"/>
                    <DataGridTextColumn Header="Mã SP" Width="120" Binding="{Binding MaSP}"/>
                    <DataGridTextColumn Header="Tên Sản Phẩm" Width="*" Binding="{Binding TenSP}"/>
                    <DataGridTextColumn Header="Số Lượng" Width="100" Binding="{Binding SoLuong}"/>
                    <DataGridTextColumn Header="Đơn Giá Nhập" Width="150" Binding="{Binding DonGiaNhap, StringFormat='{}{0:N0} đ'}"/>
                    <DataGridTextColumn Header="Thành Tiền" Width="150" Binding="{Binding ThanhTien, StringFormat='{}{0:N0} đ'}"/>
                    <DataGridTemplateColumn Header="Thao Tác" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    
                                    <Button Background="Transparent" BorderThickness="0" Margin="0,0,15,0"
                                            ToolTip="Sửa" Cursor="Hand"
                                            Command="{Binding DataContext.EditDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <Path Data="M3,17.25V21h3.75L17.81,9.94l-3.75-3.75L3,17.25z M20.71,7.04c0.39-0.39,0.39-1.02,0-1.41l-2.34-2.34c-0.39-0.39-1.02-0.39-1.41,0l-1.83,1.83l3.75,3.75L20.71,7.04z" 
                                              Fill="#107C41" Width="14" Height="14" Stretch="Fill"/>
                                    </Button>
                                   
                                    <Button Background="Transparent" BorderThickness="0"
                                            ToolTip="Xóa" Cursor="Hand"
                                            Command="{Binding DataContext.DeleteDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <Path Data="M6,19c0,1.1,0.9,2,2,2h8c1.1,0,2-0.9,2-2V7H6V19z M19,4h-3.5l-1-1h-5l-1,1H5v2h14V4z" 
                                              Fill="#C00000" Width="14" Height="14" Stretch="Fill"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Orientation="Horizontal" Grid.Row="4" Margin="10,10,10,10" Grid.ColumnSpan="2">
            <TextBlock Text="Tổng Tiền hàng:" FontSize="35" FontWeight="Bold" Foreground="DarkRed"/>
            <TextBlock Text="{Binding TongTien, StringFormat='{}{0:N0} đ'}" FontSize="35" FontWeight="Bold" Foreground="DarkRed" Margin="10,0,0,0"/>
            <Border CornerRadius="5" BorderThickness="1" BorderBrush="#A0A0A0" Height="45" Width="200" Background="DarkBlue" Margin="500,0,0,0">
                <Button BorderThickness="0" Background="Transparent" Padding="10,0" Content="📄 Lưu Hóa Đơn" Foreground="White" FontSize="20"
                        Command="{Binding SaveInvoiceCommand}"/>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>