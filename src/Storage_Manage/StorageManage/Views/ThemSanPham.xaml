<UserControl x:Class="StorageManage.Views.ThemSanPham"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StorageManage.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="THÊM SẢN PHẨM"
                       FontSize="20"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>

            <TextBox Text="{Binding TenSanPham}" Margin="5"/>

            <TextBox Text="{Binding Gia}" Margin="5"/>

            <ComboBox ItemsSource="{Binding DanhMucs}"
                      SelectedItem="{Binding SelectedDanhMuc}"
                      DisplayMemberPath="TenDanhMuc"
                      Margin="5"/>

            <DatePicker SelectedDate="{Binding NgayNhap}" Margin="5"/>

            <Image Source="{Binding ImagePath}" Height="120" Margin="5"/>

            <Button Content="Chọn ảnh"
                    Command="{Binding ChonAnhCommand}"
                    Margin="5"/>

            <Button Content="Lưu"
                    Command="{Binding SaveCommand}"
                    Margin="5"/>

        </StackPanel>
    </Grid>
</UserControl>
