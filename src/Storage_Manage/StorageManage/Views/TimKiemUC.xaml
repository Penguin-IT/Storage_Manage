<UserControl x:Class="Storage_Manage.Views.TimKiemUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Storage_Manage.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    

    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="5" FontSize="20"/>

            <!-- 1. Binding Text vào SearchText và cập nhật ngay khi gõ -->
            <TextBox Width="200" Margin="5" Name="txtSearch" 
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <TextBlock Text="Tiêu chí:" VerticalAlignment="Center" Margin="5" FontSize="20"/>
            <ComboBox Width="120" Margin="5" SelectedIndex="0">
                <ComboBoxItem Content="Theo tên"/>
                <ComboBoxItem Content="Theo mã"/>
            </ComboBox>

            <!-- 2. Binding Command vào nút bấm -->
            <Button Content="Tìm kiếm" Width="100" Margin="5" 
                    Background="SkyBlue" FontSize="20"
                    Command="{Binding SearchCommand}"/>
        </StackPanel>

        <!-- 3. Binding ItemsSource vào danh sách kết quả SearchResult -->
        <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  Name="dgSearchResult" ItemsSource="{Binding SearchResult}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Sản Phẩm" Binding="{Binding MaSP}" Width="*"/>
                <DataGridTextColumn Header="Tên Sản Phẩm" Binding="{Binding TenSP}" Width="2*"/>
                <DataGridTextColumn Header="Đơn Vị Tính" Binding="{Binding DVT}" Width="*"/>
                <DataGridTextColumn Header="Số Lượng Tồn" Binding="{Binding SLTon}" Width="*"/>
                <DataGridTextColumn Header="Đơn Giá" Binding="{Binding DonGia}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>