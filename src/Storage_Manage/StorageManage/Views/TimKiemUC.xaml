<UserControl x:Class="Storage_Manage.Views.TimKiemUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Storage_Manage.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Tìm kiếm:" VerticalAlignment="Center" Margin="5" FontSize="20"/>
            <TextBox Width="200" Margin="5" Name="txtSearch"/>

            <TextBlock Text="Tiêu chí:" VerticalAlignment="Center" Margin="5" FontSize="20"/>
            <ComboBox Width="120" Margin="5">
                <ComboBoxItem Content="Theo tên"/>
                <ComboBoxItem Content="Theo mã"/>
            </ComboBox>

            <Button Content="Tìm kiếm" Width="80" Margin="5" Background="SkyBlue" FontSize="20"/>
        </StackPanel>

        <DataGrid Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" Name="dgSearchResult">
            <!-- Sau này sẽ Binding dữ liệu vào đây -->
        </DataGrid>
    </Grid>
</UserControl>
