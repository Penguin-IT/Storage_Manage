<UserControl x:Class="Storage_Manage.Views.ThongKeDoanhThuUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Storage_Manage.Views"
             xmlns:vm="clr-namespace:StorageManage.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:StatisticViewModel/>
    </UserControl.DataContext>
    <Grid Background="White" Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Từ ngày:" VerticalAlignment="Center" Margin="5" FontSize="20"/>
           
            <DatePicker Margin="5" FontSize="20" 
                        SelectedDate="{Binding FromDate, UpdateSourceTrigger=PropertyChanged}"/>


            <TextBlock Text="Đến ngày:" VerticalAlignment="Center" Margin="5" FontSize="20"/>
            <DatePicker Margin="5" FontSize="20" SelectedDate="{Binding Path=DisplayDate, RelativeSource={RelativeSource Self}}"/>

           
            <Button Content="Thống kê" Width="120" Margin="5" 
                    Background="LightGreen" FontSize="20"
                    Command="{Binding StatisticCommand}"/>
        </StackPanel>

        
        <DataGrid Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" 
                  Name="dgStatistic" ItemsSource="{Binding OutputList}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Mã Phiếu Xuất" Binding="{Binding MaPX}" Width="*"/>
                <DataGridTextColumn Header="Ngày Xuất" Binding="{Binding NgayXuat, StringFormat=\{0:dd/MM/yyyy\}}" Width="*"/>
                <DataGridTextColumn Header="Mã Đại Lý/Khách" Binding="{Binding MaDL}" Width="*"/>
                <DataGridTextColumn Header="Tổng Tiền" Binding="{Binding TongTien, StringFormat='{}{0:N0}'}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="Margin" Value="0,0,5,0" />
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <TextBlock Text="Tổng doanh thu: " FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="{Binding TotalRevenue, StringFormat='{}{0:N0} VNĐ'}" 
                       FontSize="25" 
                       Foreground="Red" 
                       FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</UserControl>