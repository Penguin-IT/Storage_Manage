<UserControl x:Class="StorageManage.Views.PasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:StorageManage.ViewModels" 
             mc:Ignorable="d" 
             d:DesignHeight="519" d:DesignWidth="800">



    <Grid Background="#F5F6F7">
        <Border Background="White" CornerRadius="15" Margin="50" VerticalAlignment="Top" MaxWidth="400">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" Color="LightGray" ShadowDepth="2"/>
            </Border.Effect>

            <StackPanel Margin="30">
                <TextBlock Text="ĐỔI MẬT KHẨU" FontSize="22" FontWeight="Bold" Foreground="#2196F3" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBlock Text="Mật khẩu hiện tại" Margin="0,10,0,5" FontWeight="SemiBold"/>
                <PasswordBox x:Name="oldPassBox" Height="40" Tag="{Binding OldPassword, Mode=TwoWay}"/>

                <TextBlock Text="Mật khẩu mới" Margin="0,15,0,5" FontWeight="SemiBold"/>
                <PasswordBox x:Name="newPassBox" Height="40" Padding="10,5" VerticalContentAlignment="Center"/>

                <TextBlock Text="Xác nhận mật khẩu mới" Margin="0,15,0,5" FontWeight="SemiBold"/>
                <PasswordBox x:Name="confirmPassBox" Height="40" Padding="10,5" VerticalContentAlignment="Center"/>

                <Button Content="Cập Nhật Mật Khẩu" 
                        Click="btnUpdatePassword_Click" 
                        Height="45" Margin="0,30,0,0" 
                        Background="#2196F3" Foreground="White" 
                        FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>