<Window x:Class="Storage_Manage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Hệ Thống Quản Lý Nhà Kho" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    
    

    <Window.Resources>
        <!-- Style cơ bản cho nút bấm ở thanh Menu -->
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Cột Menu bên trái -->
            <ColumnDefinition Width="220"/>
            <!-- Cột Nội dung bên phải -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- THANH MENU (SIDEBAR) -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <!-- Tiêu đề / Logo -->
                <TextBlock Text="KHO HÀNG" Foreground="White" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,30,0,30"/>

                <!-- Các nút điều hướng -->
                <Button Content="Trang Chủ" Command="{Binding HomeViewCommand}" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Content="Nhập / Xuất Kho" Command="{Binding WarehouseViewCommand}" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button Content="Quản lý Sản phẩm" Command="{Binding ProductViewCommand}" 
                        Style="{StaticResource MenuButtonStyle}"/>

                <Button x:Name="btnAccountManage" Content="Quản lý Tài khoản" 
                        Command="{Binding AccountViewCommand}" 
                        Style="{StaticResource MenuButtonStyle}"/>
                <!-- Phục vụ Mục 8 -->

                <Button Content="Đổi Mật Khẩu" Command="{Binding PasswordViewCommand}" 
                        Style="{StaticResource MenuButtonStyle}"/>
                <!-- Phục vụ Mục 8 -->

                <!-- Nút Đăng xuất đặt ở dưới -->
                <Button Content="Đăng Xuất" Click="btnLogout_Click" 
                        Style="{StaticResource MenuButtonStyle}" Margin="0,50,0,0" Foreground="#E74C3C"/>
            </StackPanel>
        </Border>

        <!-- VÙNG NỘI DUNG CHÍNH (Thay đổi theo UserControl) -->
        <Border Grid.Column="1" Background="#ECF0F1">
            <Grid Margin="15">
                <!-- Thẻ ContentControl này là "trái tim" của việc điều hướng -->
                <ContentControl Content="{Binding CurrentView}" />
            </Grid>
        </Border>
        
    </Grid>
</Window>