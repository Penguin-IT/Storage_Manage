<Window x:Class="Storage_Manage.View.Login_UI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Đăng Nhập Hệ Thống" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent">

    <Border Background="White" CornerRadius="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Direction="0" ShadowDepth="0" Color="Gray"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Title -->
                <RowDefinition Height="*"/>
                <!-- Content -->
                <RowDefinition Height="Auto"/>
                <!-- Buttons -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="ĐĂNG NHẬP" FontSize="28" FontWeight="Bold" 
                           Foreground="#2196F3" HorizontalAlignment="Center"/>
                <TextBlock Text="Quản lý kho hàng" Foreground="Gray" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Input Fields -->
            <StackPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBlock Text="Tên đăng nhập" Margin="0,10,0,5" FontWeight="SemiBold"/>
                <TextBox x:Name="txtUsername" Height="40" Padding="10,5" 
                         VerticalContentAlignment="Center"
                         Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBlock Text="Mật khẩu" Margin="0,20,0,5" FontWeight="SemiBold"/>
                <!-- Lưu ý: PasswordBox không bind trực tiếp được, ta sẽ xử lý sau -->
                <PasswordBox x:Name="txtPassword" Height="40" Padding="10,5" 
                             VerticalContentAlignment="Center"/>
            </StackPanel>

            <!-- Action Buttons -->
            <StackPanel Grid.Row="2">
                <Button Content="Đăng Nhập" Height="45" Background="#2196F3" 
                        Foreground="White" FontSize="16" FontWeight="Bold"
                        Command="{Binding LoginCommand}" 
                        CommandParameter="{Binding ElementName=txtPassword}">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="Thoát" Click="HandleExit" Height="45" Margin="0,10,0,0" 
                        Background="Transparent" BorderBrush="Transparent" 
                        Foreground="Gray"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
